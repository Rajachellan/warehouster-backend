# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/warehouster

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=1h

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare Images (optional - used for TipTap image uploads)
CLOUDFLARE_IMAGES_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
# Set to "true" if you want URLs to require signed tokens (usually keep false for CMS usage)
CLOUDFLARE_IMAGES_REQUIRE_SIGNED_URLS=false

# SMTP (defaults; can be overridden via Settings in admin)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Warehouster
SMTP_FROM_EMAIL=info@warehouster.com

# Admin notification email
ADMIN_EMAIL=info@warehouster.com

# Super Admin seed (run npm run seed)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@warehouster.com
SEED_ADMIN_PASSWORD=ChangeMe123!
